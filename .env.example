# ─────────────────────────────────────────────────────────────────────────────
# Snowflake connection credentials (required)
# ─────────────────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=VEIDJBV-BR57195
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=

# ─────────────────────────────────────────────────────────────────────────────
# Dataset configuration
#
# Option A — single dataset (simple)
# ─────────────────────────────────────────────────────────────────────────────
SNOWFLAKE_DATABASE=TPCH_DATA_PRODUCT
SNOWFLAKE_SCHEMA=GOLD

# ─────────────────────────────────────────────────────────────────────────────
# Option B — multiple datasets (LLM picks the right one per question)
#
# Set SNOWFLAKE_DATASETS as a JSON array. Each entry needs:
#   db          : Snowflake database name
#   schema      : Schema within that database
#   description : Plain-English description of what data lives here
#                 (the LLM reads this to decide which dataset to query)
#
# When SNOWFLAKE_DATASETS is set it takes priority over
# SNOWFLAKE_DATABASE / SNOWFLAKE_SCHEMA above.
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: must be a single line — python-dotenv does not support multi-line values.
# SNOWFLAKE_DATASETS=[{"db":"TPCH_DATA_PRODUCT","schema":"ANALYTICS","description":"Sales orders, customer data, product performance and supplier information from the TPCH benchmark"},{"db":"FINANCE_DW","schema":"REPORTING","description":"Financial data including P&L, budget vs actuals, revenue by segment and cost centre"},{"db":"HEALTHCARE_DB","schema":"CLINICAL","description":"Patient records, clinical trial outcomes, adverse event reporting and drug efficacy data"}]

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
